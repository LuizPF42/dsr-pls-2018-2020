Package: dsrPLs2018
Title: Analise de PLs sobre Direitos Sexuais e Reprodutivos (2018-2020)
Version: 0.0.0.9000
Authors@R: c(
    person("Luiz Claudio", "Pimenta Filho", role = c("aut", "cre"),
           email = "luiz.pimenta@example.org",
           comment = "Extracao do corpus e ferramentas de analise"),
